# =============================================================================
# Content Creator Backend - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control!
# =============================================================================

# Server Configuration
# -----------------------------------------------------------------------------
NODE_ENV=development           # development | production | test
PORT=4000                      # Server port (Railway sets PORT automatically; do not override in production)

# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info                 # debug | info | warn | error

# Supabase Configuration (Required)
# -----------------------------------------------------------------------------
# Get these from your Supabase project: Dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
# REQUIRED: Use the "service_role" secret key (NOT the anon key). Backend needs it to bypass RLS
# for chat_history inserts and storage bucket creation. If you use the anon key you'll get
# "new row violates row-level security policy" when saving screenplays/slideshows.
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # Service role key (secret!) - from API → service_role
SUPABASE_ANON_KEY=eyJ...           # Anon/public key (optional, for frontend)

# OpenAI Configuration (Required)
# -----------------------------------------------------------------------------
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Runway ML Configuration (Optional)
# -----------------------------------------------------------------------------
# Get from https://dev.runwayml.com
# If not provided, Runway video generation will be disabled
RUNWAY_API_KEY=

# fal.ai Configuration (Required for video generation)
# -----------------------------------------------------------------------------
# Get from https://fal.ai/dashboard/keys
# Used for AI video generation (MiniMax, Wan, Luma, Kling models)
FAL_AI_API_KEY=

# CORS Configuration
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins, or * for all
# For production: add your frontend URL so videaa.com can call this backend (e.g. on Railway)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000,https://videaa.com,https://www.videaa.com

# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=60000     # Time window in milliseconds (default: 1 minute)
RATE_LIMIT_MAX_REQUESTS=100    # Max requests per window (default: 100)

# Moonshot / Kimi AI (Optional)
# -----------------------------------------------------------------------------
# Used for slide content generation. If not set, feature is disabled.
MOONSHOT_API_KEY=

# =============================================================================
# Production (Railway)
# =============================================================================
# Set these in Railway → Project → Variables (never in git).
# Required: NODE_ENV=production, PORT (set by Railway), SUPABASE_URL,
#           SUPABASE_SERVICE_ROLE_KEY, OPENAI_API_KEY, CORS_ORIGIN.
# CORS_ORIGIN: comma-separated allowed origins, e.g. https://www.videaa.com,https://videaa.com
# Optional: RUNWAY_API_KEY, FAL_AI_API_KEY, MOONSHOT_API_KEY, LOG_LEVEL.
